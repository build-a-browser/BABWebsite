---
import { Image } from 'astro:assets';
import DemoScreenshot from '../assets/demo_screenshot.png';
import StepList from '../components/StepList.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title={"Build a browser!"}>
	<div class="intro-card">
		<h1>BuildABrowser</h1>
		<p>
			BuildABrowser is a project aiming to build a browser and its rendering engine in Java, and then document it
			such that others can rebuild it for themselves.
		</p>
		<span id="demo-links">
			<a href="#demo">Jump to Screenshots</a> |
			<a href="https://youtube.com/">View on <span style="color: #ff0033;">YouTube</span></a>
		</span>
	</div>
	<div class="semicentered section">
		<h2>Download a build:</h2>
	</div>
	<div id="downloads" class="semicentered">
		<a href="about:blank"><button class="nav-button ac-4">Linux (Tested on Arch, btw)</button></a>
		<a href="about:blank"><button class="nav-button ac-1">Windows (Tested on Windows 11)</button></a>
		<a href="about:blank"><button class="nav-button ac-2">MacOS (Not Tested)</button></a>
	</div>
	<div id="command" class="semicentered section">
		<h4>Java 24:</h4>
		<code>
			java -Xms32m
				-XX:MaxHeapFreeRatio=10 -XX:MinHeapFreeRatio=10
				-XX:+UnlockExperimentalVMOptions -XX:+UseCompactObjectHeaders
				-Djava.net.preferIPv4Stack=true -jar buildabrowser.jar
		</code>
		<h4>Java 25 (LTS):</h4>
		<code>
			java -Xms32m
				-XX:MaxHeapFreeRatio=10 -XX:MinHeapFreeRatio=10
				-Djava.net.preferIPv4Stack=true -jar buildabrowser.jar
		</code>
		<p>
			By default, BuildABrowser uses Skija for drawing. You can use Java2D by adding the <span class="small-code">--use-java2d</span>.
		</p>
	</div>
	<div class="semicentered section">
		<h2>Take a look at some steps:</h2>
	</div>
	<StepList max={6}/>
	<div class="semicentered section">
		<a href="/steps"><button class="nav-button ac-1 all-steps">All Steps</button></a>
	</div>
	<div id="demo" class="section">
		<h2>See a demo!</h2>
		<a href={DemoScreenshot.src}>
			<Image
				src={DemoScreenshot}
				alt="A screenshot containing two BuildABrowser windows"
				width="1920"
				id="demo-screenshot"
			/>
		</a>
	</div>
	<footer class="section">
		Created by Jason Gronn (@EveryOS) | <a href="mailto:jgronn@buildabrowser.net">mailto:jgronn@buildabrowser.net</a><br/>
		Socials
		| <a href="https://github.com/JasonTheKitten/">GitHub</a>
		| <a href="https://www.linkedin.com/in/jason-gronn/">LinkedIn</a>
		| <a href="https://www.deviantart.com/everyos">DeviantArt</a>
		| <a href="https://news.ycombinator.com/user?id=everyos_">Hacker News</a>
		| <a href="https://old.reddit.com/user/everyos/" style="font-size: .75em;">Reddit</a>
		| Discord: everyos
	</footer>
</Layout>

<style>
	.intro-card {
		text-align: center;
		margin: 4em;
	}
	.intro-card p {
		margin: auto;
		max-width: 40em;
	}
	.intro-card h1 {
		font-size: xxx-large;
	}

	.section {
		margin: 1em auto;
		padding: 0 2em;
	}
	.all-steps {
		width: min(80vw, 20em);
	}

	.small-code {
		font-family: monospace;
		display: inline-block;
		color: var(--color-foreground-small-code, maroon);
	}

	#demo-links {
		display: block;
		margin: .5em;
	}
	#demo-links a {
		color: gray;
	}

	#downloads {
		display: flex;
		flex-wrap: wrap;
		padding: 0 2em;
		column-gap: 2em;
	}
	#downloads > * {
		flex-grow: 1;
	}
	#downloads > a {
		flex-grow: 1;
		text-decoration: none;
	}
	#downloads .nav-button {
		box-sizing: border-box;
		display: block;
		width: 100%;
	}

	#command p {
		max-width: 55em;
	}
	#command code {
		white-space: nowrap;
		max-width: 100%;
		overflow: auto;
		display: block;
	}

	#demo {
		background-color: var(--color-background-secondary);
		padding: 2em 0;
		text-align: center;
	}
	#demo-screenshot {
		width: clamp(50%, 80em, 100%);
		height: auto;
		margin: auto;
	}

	footer {
		position: sticky;
		bottom: 1em;
		left: 0
	}

	footer a {
		color: white;
	}

	@media screen and (max-width: 500px) {	
		.intro-card h1 {
			font-size: xx-large;
		}

		footer {
			position: static;
		}
	}
</style>
